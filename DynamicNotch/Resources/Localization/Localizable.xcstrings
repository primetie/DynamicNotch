    "Add a soft glow around the HUD level indicator." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Add a soft glow around the HUD level indicator."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Añade un brillo suave alrededor del indicador de nivel del HUD."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Добавить мягкое свечение вокруг индикатора уровня HUD."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "为 HUD 级别指示器添加柔和光晕。"
          }
        }
      }
    },
    "Add this suffix before the converted file extension." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Add this suffix before the converted file extension."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Añade este sufijo antes de la extensión del archivo convertido."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Добавляет этот суффикс перед расширением сконвертированного файла."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在转换后的文件扩展名前添加此后缀。"
          }
        }
      }
    },
    "Adjust how quickly press-and-hold and hover expansion trigger." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adjust how quickly press-and-hold and hover expansion trigger."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajusta la rapidez con la que se activan la expansión al mantener pulsado y al pasar el cursor."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Настройте, как быстро срабатывает раскрытие при удержании и наведении."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "调整按住和悬停展开的触发速度。"
          }
        }
      }
    },
    "Adjust how quickly the notch press peaks and hold-to-expand triggers." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adjust how quickly the notch press peaks and hold-to-expand triggers."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajusta la rapidez con la que la pulsación en la muesca alcanza su punto máximo y activa la expansión al mantener pulsado."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Настройте, как быстро нажатие на вырез достигает пика и срабатывает раскрытие по удержанию."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "调整按下刘海达到峰值以及长按展开触发的速度。"
          }
        }
      }
    },
    "Adjust the thickness of the notch outline." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adjust the thickness of the notch outline."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajuste el grosor del contorno de la muesca."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Настройте толщину обводки выреза."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "调整凹口轮廓的厚度。"
          }
        }
      }
    },
