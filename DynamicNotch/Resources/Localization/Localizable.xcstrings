    "settings.about.feature.liveActivity.description" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Persistent notch content stays visible for as long as the source event is active, then fades away when it ends."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El contenido persistente del notch permanece visible mientras el evento de origen esté activo y se desvanece cuando termina."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Постоянный контент в notch остаётся видимым, пока активно исходное событие, а затем исчезает после его завершения."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只要源事件处于活动状态，notch 中的持久内容就会保持可见，并在事件结束后淡出。"
          }
        }
      }
    },
