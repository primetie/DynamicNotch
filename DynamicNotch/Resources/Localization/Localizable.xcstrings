    "Allow gestures to bring back the most recently dismissed activity." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allow gestures to bring back the most recently dismissed activity."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permite que los gestos recuperen la actividad descartada más recientemente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Разрешить жестами возвращать последнюю скрытую активность."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "允许通过手势恢复最近隐藏的活动。"
          }
        }
      }
    },
    "Allow gestures to hide the currently visible live or temporary activity." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allow gestures to hide the currently visible live or temporary activity."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permite que los gestos oculten la actividad en vivo o temporal visible actualmente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Разрешить жестами скрывать текущую видимую live activity или временную активность."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "允许通过手势隐藏当前可见的实时活动或临时活动。"
          }
        }
      }
    },
    "Allow the selected notch gesture to open the expanded live activity layout when supported." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allow the selected notch gesture to open the expanded live activity layout when supported."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permite que el gesto seleccionado de la muesca abra el diseño expandido de la actividad en vivo cuando esté disponible."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Разрешить выбранным жестом открывать расширенный режим live activity, если он поддерживается."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "允许所选刘海手势在支持时打开实时活动的展开布局。"
          }
        }
      }
    },
    "Animate artwork with a 3D flip when the track cover changes." : {
